# KIN Platform Environment Variables

# =============================================================================
# Required
# =============================================================================

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# JWT Authentication (random secure string)
JWT_SECRET=your_secure_jwt_secret_here

# =============================================================================
# Local LLM (Ollama)
# =============================================================================

OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# Local Voice Pipeline (zero-cost, open source)
# =============================================================================

# Local STT — whisper.cpp (https://github.com/ggerganov/whisper.cpp)
LOCAL_WHISPER_ENABLED=false
WHISPER_CPP_PATH=whisper-cpp
WHISPER_MODEL_PATH=
WHISPER_THREADS=4

# Local TTS — XTTS v2 for voice cloning (https://github.com/coqui-ai/TTS)
# Start server: tts --model_name tts_models/multilingual/multi-dataset/xtts_v2 --server
XTTS_SERVER_URL=http://localhost:8020
LOCAL_TTS_PROVIDER=xtts
VOICE_PROFILES_DIR=./voice/profiles

# Local TTS — Piper fallback (https://github.com/rhasspy/piper)
PIPER_PATH=piper
PIPER_MODEL_PATH=

# =============================================================================
# Cloud Fallback (recommended)
# =============================================================================

# OpenAI (for fallback LLM and Whisper transcription)
OPENAI_API_KEY=

# Anthropic (alternative fallback)
ANTHROPIC_API_KEY=

# =============================================================================
# Voice Processing
# =============================================================================

# ElevenLabs (TTS voice synthesis)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# =============================================================================
# Database & Server
# =============================================================================

DATABASE_PATH=./data/kin.db
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# =============================================================================
# Solana (NFT Integration)
# =============================================================================

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=

# =============================================================================
# Tailscale (Remote Access)
# =============================================================================

TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# =============================================================================
# Web Search (Skills)
# =============================================================================

# Tavily (https://tavily.com — free tier available)
TAVILY_API_KEY=

# =============================================================================
# Monitoring & Notifications
# =============================================================================

SLACK_WEBHOOK_URL=
ALERT_CHAT_ID=
