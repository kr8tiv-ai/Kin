{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WebsiteSpecialistRequestRecord",
  "description": "Bounded support-safe intake record for website-specialist work, separate from Telegram, Cipher, and generic runtime-step seams.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string" },
    "request_source": { "type": "string", "enum": ["telegram_voice_turn", "operator_restore", "system_handoff"] },
    "request_status": { "type": "string", "enum": ["activation_ready", "blocked", "needs_route_decision"] },
    "support_safe_request_summary": { "type": "string" },
    "desired_outcome_summary": { "type": "string" },
    "activation_ready": { "type": "boolean" },
    "activation_ref": { "type": "string" },
    "voice_turn_ref": { "type": ["string", "null"] },
    "continuity_ref": { "type": ["string", "null"] },
    "requested_capability": {
      "type": "string",
      "enum": ["website_update", "landing_page", "diagnostic_review", "content_refresh"]
    }
  },
  "required": [
    "request_id",
    "request_source",
    "request_status",
    "support_safe_request_summary",
    "desired_outcome_summary",
    "activation_ready",
    "activation_ref",
    "voice_turn_ref",
    "continuity_ref",
    "requested_capability"
  ]
}
