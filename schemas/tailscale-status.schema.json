{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TailscaleStatus",
  "description": "Network status record for Tailscale VPN devices in the Kin tailnet. Used for remote access monitoring and device pairing in Mission Control.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^tss-[a-z0-9]+$",
      "description": "Unique identifier for this status record (prefix: tss-)"
    },
    "schema_family": {
      "type": "string",
      "enum": ["tailscale_status"],
      "description": "Schema family identifier for versioning"
    },
    "tailnet": {
      "type": "string",
      "description": "Name of the Tailscale network (tailnet)"
    },
    "devices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TailscaleDevice"
      },
      "description": "List of devices in the tailnet"
    },
    "network_health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_devices": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of devices in the tailnet"
        },
        "online_devices": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of currently online devices"
        },
        "offline_devices": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of currently offline devices"
        },
        "health_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Network health score (0-100)"
        },
        "last_check": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last health check"
        }
      },
      "required": ["total_devices", "online_devices", "offline_devices", "health_score", "last_check"]
    },
    "auth_key": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "type": "string",
          "description": "ID of the current auth key (not the key itself)"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when auth key expires"
        },
        "reusable": {
          "type": "boolean",
          "description": "Whether the auth key can be used multiple times"
        }
      },
      "description": "Current auth key information (key value never stored)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this record was created"
    }
  },
  "required": [
    "record_id",
    "schema_family",
    "tailnet",
    "devices",
    "network_health",
    "created_at"
  ],
  "$defs": {
    "TailscaleDevice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "device_id": {
          "type": "string",
          "description": "Unique Tailscale device identifier"
        },
        "hostname": {
          "type": "string",
          "description": "Device hostname"
        },
        "ip_addresses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tailscale IP addresses (IPv4 and IPv6)"
        },
        "online": {
          "type": "boolean",
          "description": "Whether the device is currently online"
        },
        "last_seen": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last activity"
        },
        "os": {
          "type": "string",
          "description": "Operating system (linux, windows, macos, ios, android)"
        },
        "user": {
          "type": "string",
          "description": "Tailscale user who owns this device"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "ACL tags applied to this device"
        },
        "is_kin_host": {
          "type": "boolean",
          "description": "Whether this device hosts a Kin companion"
        },
        "kin_id": {
          "type": "string",
          "description": "Kin companion ID if this device hosts a Kin"
        }
      },
      "required": [
        "device_id",
        "hostname",
        "ip_addresses",
        "online",
        "last_seen",
        "os"
      ]
    }
  }
}
