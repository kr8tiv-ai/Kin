{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TelegramVoiceContinuity",
  "description": "Machine-readable session continuity state for a Telegram voice turn.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "continuity_status": {
      "type": "string",
      "enum": ["new_session", "same_session", "carryover"]
    },
    "session_reference": {
      "type": "string"
    },
    "turns_in_session": {
      "type": "integer"
    },
    "carryover_summary": {
      "type": "string"
    },
    "prior_turn_reference": {
      "type": ["string", "null"]
    },
    "memory_scope": {
      "type": "string",
      "enum": ["none", "session_only", "support_safe_carryover"]
    }
  },
  "required": [
    "continuity_status",
    "session_reference",
    "turns_in_session",
    "carryover_summary",
    "prior_turn_reference",
    "memory_scope"
  ]
}
