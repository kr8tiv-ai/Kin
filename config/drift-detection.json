{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DriftDetectionConfig",
  "description": "Configuration for Kin behavioral drift detection",
  "default_threshold": 0.20,
  "severity_thresholds": {
    "low": 0.20,
    "medium": 0.30,
    "high": 0.40,
    "critical": 0.50
  },
  "check_interval_multiplier": 10,
  "history_size": 100,
  "minimum_samples_for_drift": 5,
  "baseline_period_days": 7,
  "alert_notification_channels": [
    "mission-control",
    "telegram"
  ],
  "auto_acknowledge_stable_after_hours": 24,
  "specialization_defaults": {
    "web-design": {
      "expected_response_time_seconds": 12,
      "expected_completion_rate": 0.95,
      "expected_error_rate": 0.02,
      "expected_alignment_score": 0.90
    },
    "family-companion": {
      "expected_response_time_seconds": 8,
      "expected_completion_rate": 0.98,
      "expected_error_rate": 0.01,
      "expected_alignment_score": 0.95
    },
    "social-media": {
      "expected_response_time_seconds": 15,
      "expected_completion_rate": 0.92,
      "expected_error_rate": 0.03,
      "expected_alignment_score": 0.88
    },
    "developer-support": {
      "expected_response_time_seconds": 20,
      "expected_completion_rate": 0.90,
      "expected_error_rate": 0.03,
      "expected_alignment_score": 0.85
    },
    "creative-writing": {
      "expected_response_time_seconds": 18,
      "expected_completion_rate": 0.94,
      "expected_error_rate": 0.02,
      "expected_alignment_score": 0.92
    },
    "wealth-coaching": {
      "expected_response_time_seconds": 22,
      "expected_completion_rate": 0.93,
      "expected_error_rate": 0.02,
      "expected_alignment_score": 0.90
    }
  },
  "metric_weights": {
    "response_time": 0.20,
    "task_completion": 0.30,
    "error_rate": 0.25,
    "specialization_alignment": 0.25
  },
  "trend_window_size": 10,
  "trend_minimum_samples": 3
}
