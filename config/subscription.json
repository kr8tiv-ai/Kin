{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "stripe": {
    "api_key_env": "STRIPE_SECRET_KEY",
    "webhook_secret_env": "STRIPE_WEBHOOK_SECRET",
    "api_version": "2023-10-16"
  },
  "price_ids": {
    "hatchling": {
      "monthly": "price_hatchling_monthly",
      "yearly": "price_hatchling_yearly"
    },
    "elder": {
      "monthly": "price_elder_monthly",
      "yearly": "price_elder_yearly"
    },
    "hero": {
      "monthly": "price_hero_monthly",
      "yearly": "price_hero_yearly"
    }
  },
  "trial_period_days": 14,
  "grace_period_days": 7,
  "webhook_events": [
    "customer.subscription.created",
    "customer.subscription.updated",
    "customer.subscription.deleted",
    "invoice.paid",
    "invoice.payment_failed"
  ],
  "notification_channels": {
    "subscription_created": ["email"],
    "subscription_updated": ["email", "mission-control"],
    "subscription_canceled": ["email"],
    "payment_failed": ["email", "telegram"],
    "trial_ending": ["email", "mission-control"]
  }
}
