{
  "kin_processes": [
    {
      "kin_id": "api-server",
      "name": "API Server",
      "health_endpoint": "http://localhost:3000/health/live",
      "process_name": "node",
      "restart_command": "npm run start",
      "health_timeout_ms": 5000,
      "max_consecutive_errors": 3,
      "auto_restart": true
    },
    {
      "kin_id": "telegram-bot",
      "name": "Telegram Bot",
      "health_endpoint": "http://localhost:3000/health/live",
      "process_name": "node",
      "restart_command": "npm run start:bot",
      "health_timeout_ms": 5000,
      "max_consecutive_errors": 5,
      "auto_restart": true
    }
  ],
  "drift_detection": {
    "enabled": true,
    "check_interval_seconds": 300,
    "baseline_file": "./config/drift-baselines.json",
    "alert_threshold": 0.7
  },
  "notifications": {
    "slack_webhook": "${SLACK_WEBHOOK_URL}",
    "telegram_bot_token": "${TELEGRAM_BOT_TOKEN}",
    "telegram_chat_id": "${ALERT_CHAT_ID}"
  }
}
