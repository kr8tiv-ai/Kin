FROM node:20-alpine AS build

WORKDIR /app/web

ENV NEXT_TELEMETRY_DISABLED=1

# Build-time env vars baked into the Next.js client bundle
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=${NEXT_PUBLIC_GOOGLE_CLIENT_ID}

ARG NEXT_PUBLIC_SENTRY_DSN
ENV NEXT_PUBLIC_SENTRY_DSN=${NEXT_PUBLIC_SENTRY_DSN}

COPY web/package.json web/package-lock.json ./
RUN npm ci

COPY web/next.config.ts ./
COPY web/tsconfig.json ./
COPY web/next-env.d.ts ./
COPY web/postcss.config.mjs ./
COPY web/tailwind.config.ts ./
COPY web/sentry.client.config.ts ./
COPY web/sentry.server.config.ts ./
COPY web/sentry.edge.config.ts ./
COPY web/src/ ./src/
COPY web/public/ ./public/
COPY web/i18n/ ./i18n/
COPY web/messages/ ./messages/
RUN npm run build

FROM node:20-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=3001

LABEL org.opencontainers.image.title="kin-web" \
      io.kr8tiv.kin.service="web"

COPY --from=build /app/web/public ./public
COPY --from=build /app/web/.next/standalone ./
COPY --from=build /app/web/.next/static ./.next/static

# Create non-root user
RUN addgroup -S app && adduser -S app -G app

# Ensure .next cache directory has correct ownership
RUN chown -R app:app .next

USER app

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3001/ || exit 1

CMD ["node", "server.js"]
